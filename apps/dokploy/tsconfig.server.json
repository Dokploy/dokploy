{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"module": "ESNext",
		"outDir": "dist/",
		"target": "ESNext",
		"isolatedModules": false,
		"noEmit": false,
		"moduleResolution": "Node",
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"],
			"@dokploy/server/*": ["../../packages/server/src/*"]
		}
	},
	"include": [
		"next-env.d.ts",
		"./src/server/**/*",
		"./src/migration.ts",
		"./src/setup.ts",
		"./src/wait-for-postgres.ts",
		"./src/reset-password.ts",
		"./src/reset-2fa.ts"
	]
}
