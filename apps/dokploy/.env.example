# Публичный URL приложения (без завершающего /). Нужен для редиректов Тинькофф и вебхука.
# Пример: https://deploy.example.com или http://85.239.58.191:3000
# NEXT_PUBLIC_APP_URL=
# Либо только на сервере: APP_URL=
# TINKOFF_TERMINAL_KEY=
# TINKOFF_PASSWORD=

# Cloud mode: email verification on sign-up needs SMTP (or leave SMTP_SERVER unset in development to log verifyUrl instead).
# IS_CLOUD=true
# SMTP_SERVER=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=
# Optional HubSpot (otherwise you will see "HubSpot configuration missing" in logs):
# HUBSPOT_PORTAL_ID=
# HUBSPOT_FORM_GUID=
# Social login (omit or set both for each provider):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
